                "options": [
                  { "value": "",        "label": "(default — derived from scope)",      "grouping": "" },
                  { "value": "submit",  "label": "submit (eligibility default)",        "grouping": "" },
                  { "value": "save",    "label": "save (quality default)",              "grouping": "" },
                  { "value": "manual",  "label": "manual (only when explicitly invoked)","grouping": "" },
                  { "value": "field_change", "label": "field_change (bot_pull style)",  "grouping": "" }
                ],
                "optionsBinder": { "className": "", "properties": {} },
                "validator":     { "className": "", "properties": {} }
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": {
            "width": "50%"
          },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "aggregation",
