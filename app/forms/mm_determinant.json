              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "tabCode",
                "label": "Tab code (quality scope only — groups issues by wizard tab)",
                "size": "64",
                "placeholder": "e.g. identity, geography",
                "validator": { "className": "", "properties": {} }
              }
