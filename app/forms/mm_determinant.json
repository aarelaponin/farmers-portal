                  "properties": {
                    "formDefId": "mm_service",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "groupingColumn": "",
                    "extraCondition": "",
                    "addEmptyOption": "true",
                    "emptyLabel": "",
                    "useAjax": "",
                    "cacheInterval": ""
                  }
                },
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "type": "",
                    "message": ""
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "registrationId",
                "label": "Registration (optional; null = service-level)",
