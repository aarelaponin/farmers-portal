                  { "value": "disposition", "label": "disposition (per-application — eligibility)",    "grouping": "" },
                  { "value": "issue_list",  "label": "issue_list (per-record open issue — quality)",   "grouping": "" }
                ],
                "optionsBinder": { "className": "", "properties": {} },
                "validator":     { "className": "", "properties": {} }
              }
            },
            {
