            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "scope",
                "label": "Scope",
                "options": [
                  {
                    "value": "field",
                    "label": "field (visibility / requiredness)",
                    "grouping": ""
                  },
                  {
                    "value": "screen",
                    "label": "screen (visibility of step)",
                    "grouping": ""
                  },
                  {
                    "value": "document",
                    "label": "document (conditional doc requirement)",
                    "grouping": ""
                  },
                  {
                    "value": "fee",
