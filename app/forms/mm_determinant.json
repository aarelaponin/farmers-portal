                "options": [
                  {
                    "value": "true",
                    "label": "Yes",
                    "grouping": ""
                  }
                ],
                "optionsBinder": {
                  "className": "",
                  "properties": {}
                },
                "validator": {
                  "className": "",
                  "properties": {}
                }
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "ruleSection",
        "label": "Rule + Action"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": {
            "width": "100%"
          },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "ruleJson",
                "label": "Rule JSON (fast-path AST or DSL source per ADR-001r2)",
                "rows": "8",
                "cols": "60",
                "placeholder": "Fast-path: {\"op\": \"lte\", \"left\": \"$registry.farmers.totalParcelHectares\", \"right\": 2}\\n\\nSQL-path: count($registry.applications WHERE applicantId = $applicant.nationalId AND status = 'approved') == 0",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "type": "",
                    "message": ""
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "actionJson",
                "label": "Action JSON",
                "rows": "4",
                "cols": "60",
                "placeholder": "{\"action\": \"applicable\", \"target\": \"registration:MM-REG-XXXXXX\"}",
                "validator": {
                  "className": "",
                  "properties": {}
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "failMessage",
                "label": "Fail Message (shown to citizen / operator)",
                "size": "255",
                "validator": {
                  "className": "",
                  "properties": {}
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "targetValue",
                "label": "Target Value (for assignment-type rules — ADR-027 / ADR-028)",
                "size": "64",
                "placeholder": "e.g. auto_approved, approved, sent_back",
                "validator": {
                  "className": "",
                  "properties": {}
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "description",
                "label": "Description (operator-facing)",
                "rows": "3",
                "cols": "60",
                "validator": {
                  "className": "",
                  "properties": {}
                }
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
