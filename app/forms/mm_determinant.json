{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "mm_determinant",
    "name": "MM - Determinant",
    "tableName": "mm_determinant",
    "description": "Conditional logic record: scope, rule, action. Per RegBB spec \u00a74.1.11 / \u00a77.2.12. Lesotho extension per D6: score + ruleType for the scoring evaluation strategy. Rule grammar per ADR-001r2 (DSL canonical, fast-path subset closed-twenty).",
