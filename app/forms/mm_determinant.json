                "optionsBinder": {
                  "className": "",
                  "properties": {}
                },
                "value": "inclusion",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "type": "",
                    "message": ""
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "score",
