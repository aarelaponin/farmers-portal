                  {
                    "value": "exclusion",
                    "label": "exclusion (must NOT match)",
                    "grouping": ""
                  },
                  {
                    "value": "priority",
                    "label": "priority (scored when true)",
                    "grouping": ""
                  },
                  {
                    "value": "bonus",
                    "label": "bonus (scored when true)",
                    "grouping": ""
