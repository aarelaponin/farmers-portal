                  { "value": "error",   "label": "error (blocks gates)",               "grouping": "" },
                  { "value": "warning", "label": "warning (informational only)",       "grouping": "" }
                ],
                "optionsBinder": { "className": "", "properties": {} },
                "validator":     { "className": "", "properties": {} }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
