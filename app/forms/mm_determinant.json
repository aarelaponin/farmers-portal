      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "storeBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "permission": {
      "className": "",
      "properties": {}
    },
    "noPermissionMessage": "",
    "postProcessor": {
      "className": "",
      "properties": {}
    },
    "postProcessorRunOn": "create"
  },
  "elements": [
