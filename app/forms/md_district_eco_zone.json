{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "md_district_eco_zone",
    "name": "MD.95 - District × Ecological Zone",
    "tableName": "md_district_eco_zone",
    "description": "Master data — per-(district, agro-ecological-zone) polygon centroid sourced from the customer's Ecological_Zones shapefile (Bureau of Statistics, 2023). 25 rows: 4 zones × Lesotho's 10 districts (some combinations don't exist). Used by parcelGeometry to dynamically centre the GIS map on the citizen's selected district + zone.",
    "loadBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "storeBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    }
  },
  "elements": [
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": { "id": "section_identity", "label": "Identity" },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "code",
                "label": "Code",
                "placeholder": "lowlands_maseru",
                "size": "60",
                "validator": {
                  "className": "org.joget.apps.form.lib.DuplicateValueValidator",
                  "properties": {
                    "formDefId": "md_district_eco_zone",
                    "fieldId": "code",
                    "errorDuplicateMsg": "This (district, zone) code already exists",
                    "mandatory": "true"
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "district",
                "label": "District",
                "controlField": "",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                },
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "md03district",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "addEmptyOption": "true",
                    "emptyLabel": "-- choose district --"
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "agro_zone",
                "label": "Agro-ecological zone",
                "controlField": "",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                },
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "md04agroEcologicalZo",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "addEmptyOption": "true",
                    "emptyLabel": "-- choose zone --"
                  }
                }
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "centroid_lat",
                "label": "Centroid latitude",
                "placeholder": "-29.6",
                "size": "20",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "centroid_lon",
                "label": "Centroid longitude",
                "placeholder": "28.2",
                "size": "20",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "area_km2",
                "label": "Area (km²)",
                "size": "20"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "notes",
                "label": "Notes",
                "rows": "3",
                "cols": "60",
                "placeholder": "Source: Bureau of Statistics Ecological_Zones shapefile, 2023."
              }
            }
          ]
        }
      ]
    }
  ]
}
