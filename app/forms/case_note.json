return;redirected=true;setTimeout(function(){window.location.href=reviewUrl;},600);}function attach(){var forms=document.querySelectorAll('form');for(var i=0;i<forms.length;i++){var f=forms[i];if(f.dataset.cnArm)continue;f.dataset.cnArm='1';f.addEventListener('submit',function(){var deadline=Date.now()+30000;var t=setInterval(function(){if(redirected||Date.now()>deadline){clearInterval(t);return;}var alerts=document.querySelectorAll('.alert, [class*=\"alert-success\"], .form-submitted, [id*=\"submitted\"]');for(var j=0;j<alerts.length;j++){if(/submitted/i.test(alerts[j].textContent||'')){clearInterval(t);fire();return;}}},250);});}}attach();new MutationObserver(attach).observe(document.body,{childList:true,subtree:true});}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',armPostSaveRedirect);}else{armPostSaveRedirect();}})();</script>"
