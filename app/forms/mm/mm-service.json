{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "mm_service",
    "name": "MM - Service",
    "tableName": "mm_service",
    "description": "Root of a service definition. Versioned. Groups one or more Registrations (Single-Window pattern per spec \u00a74.1.3 / \u00a76.3.1.9). Per RegBB spec \u00a74.1.2 / \u00a77.2.2.",
    "loadBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "storeBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "permission": {
      "className": "",
      "properties": {}
    },
    "noPermissionMessage": "",
    "postProcessor": {
      "className": "",
      "properties": {}
    },
    "postProcessorRunOn": "create"
  },
  "elements": [
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "identitySection",
        "label": "Service Identity"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": {
            "width": "50%"
          },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "code",
                "label": "Service Code (immutable)",
                "size": "32",
                "maxlength": "32",
                "validator": {
                  "className": "org.joget.apps.form.lib.DuplicateValueValidator",
                  "properties": {
                    "formDefId": "mm_service",
                    "fieldId": "code",
                    "errorDuplicateMsg": "This Service code already exists",
                    "mandatory": "true",
                    "regex": "",
                    "errorFormatMsg": ""
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "name",
                "label": "Service Name",
                "size": "255",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "type": "",
                    "message": ""
                  }
                }
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": {
            "width": "50%"
          },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "version",
                "label": "Version",
                "size": "16",
                "value": "1.0",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "type": "",
                    "message": "MAJOR.MINOR (e.g. 1.0, 1.1, 2.0)"
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "status",
                "label": "Status",
                "options": [
                  {
                    "value": "draft",
                    "label": "Draft",
                    "grouping": ""
                  },
                  {
                    "value": "published",
                    "label": "Published",
                    "grouping": ""
                  },
                  {
                    "value": "retired",
                    "label": "Retired",
                    "grouping": ""
                  }
                ],
                "optionsBinder": {
                  "className": "",
                  "properties": {}
                },
                "value": "draft",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "type": "",
                    "message": ""
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "institutionId",
                "label": "Owning Institution",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "mm_institution",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "groupingColumn": "",
                    "extraCondition": "",
                    "addEmptyOption": "true",
                    "emptyLabel": "",
                    "useAjax": "",
                    "cacheInterval": ""
                  }
                },
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "type": "",
                    "message": ""
                  }
                }
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "descriptionSection",
        "label": "Description"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": {
            "width": "100%"
          },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "description",
                "label": "Description",
                "rows": "4",
                "cols": "60",
                "validator": {
                  "className": "",
                  "properties": {}
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "attributesJson",
                "label": "Service-level Attributes (JSON, optional)",
                "rows": "4",
                "cols": "60",
                "placeholder": "Empty for Lesotho subsidy (umbrella service has no programme-level facts; those live on mm_registration per D16). Reserved for future service-level facts.",
                "validator": {
                  "className": "",
                  "properties": {}
                }
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "publishMetaSection",
        "label": "Publish Metadata"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": {
            "width": "100%"
          },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.DatePicker",
              "properties": {
                "id": "publishedAt",
                "label": "Published At",
                "format": "yyyy-MM-dd",
                "readonly": "true",
                "readonlyLabel": "true",
                "validator": {
                  "className": "",
                  "properties": {}
                }
              }
            }
          ]
        }
      ]
    }
  ]
}