{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "mm_catalog",
    "name": "MM - Catalog",
    "tableName": "mm_catalog",
    "description": "A reusable list of options. Instance- or service-scoped. Source can be static items or a registry capability. Per RegBB spec \u00a74.1.9 / \u00a76.3.2.2.",
    "loadBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "storeBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "permission": {
      "className": "",
      "properties": {}
    },
    "noPermissionMessage": "",
    "postProcessor": {
      "className": "",
      "properties": {}
    },
    "postProcessorRunOn": "create"
  },
  "elements": [
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "identitySection",
        "label": "Identity"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": {
            "width": "50%"
          },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "code",
                "label": "Catalog Code (immutable, e.g. district, country)",
                "size": "64",
                "validator": {
                  "className": "org.joget.apps.form.lib.DuplicateValueValidator",
                  "properties": {
                    "formDefId": "mm_catalog",
                    "fieldId": "code",
                    "errorDuplicateMsg": "This Catalog code already exists",
                    "mandatory": "true",
                    "regex": "",
                    "errorFormatMsg": ""
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "name",
                "label": "Catalog Name",
                "size": "255",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "type": "",
                    "message": ""
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "version",
                "label": "Version",
                "size": "16",
                "value": "1.0",
                "validator": {
                  "className": "",
                  "properties": {}
                }
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": {
            "width": "50%"
          },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "scope",
                "label": "Scope",
                "options": [
                  {
                    "value": "instance",
                    "label": "Instance (shared across all services)",
                    "grouping": ""
                  },
                  {
                    "value": "service",
                    "label": "Service-scoped",
                    "grouping": ""
                  }
                ],
                "optionsBinder": {
                  "className": "",
                  "properties": {}
                },
                "value": "instance",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "type": "",
                    "message": ""
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "serviceId",
                "label": "Service (when scope=service)",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "mm_service",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "groupingColumn": "",
                    "extraCondition": "",
                    "addEmptyOption": "true",
                    "emptyLabel": "(n/a)",
                    "useAjax": "",
                    "cacheInterval": ""
                  }
                },
                "validator": {
                  "className": "",
                  "properties": {}
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "source",
                "label": "Source",
                "options": [
                  {
                    "value": "static",
                    "label": "Static items (itemsJson)",
                    "grouping": ""
                  },
                  {
                    "value": "registry",
                    "label": "Registry (via IM capability)",
                    "grouping": ""
                  }
                ],
                "optionsBinder": {
                  "className": "",
                  "properties": {}
                },
                "value": "static",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "type": "",
                    "message": ""
                  }
                }
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "contentSection",
        "label": "Content"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": {
            "width": "100%"
          },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "itemsJson",
                "label": "Items JSON (when source=static)",
                "rows": "8",
                "cols": "60",
                "placeholder": "[{\"value\": \"maseru\", \"label\": \"Maseru\"}, {\"value\": \"berea\", \"label\": \"Berea\"}, ...]",
                "validator": {
                  "className": "",
                  "properties": {}
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "imCapabilityRef",
                "label": "IM Capability Ref (when source=registry)",
                "rows": "2",
                "cols": "60",
                "placeholder": "{\"source\": \"farmers\", \"path\": \"districtCatalogue\"}",
                "validator": {
                  "className": "",
                  "properties": {}
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "description",
                "label": "Description",
                "rows": "3",
                "cols": "60",
                "validator": {
                  "className": "",
                  "properties": {}
                }
              }
            }
          ]
        }
      ]
    }
  ]
}