{"elements":[{"elements":[{"elements":[{"className":"org.joget.apps.form.lib.HiddenField","properties":{"useDefaultWhenEmpty":"","validator":{"className":"","properties":{}},"workflowVariable":"","id":"parent_id","value":""}},{"className":"org.joget.apps.form.lib.HiddenField","properties":{"useDefaultWhenEmpty":"","validator":{"className":"","properties":{}},"workflowVariable":"","id":"declaration_key","value":"#form.farmerRegistrationForm.id#"}},{"className":"org.joget.apps.form.lib.CustomHTML","properties":{"id":"declarationHeader","label":"","value":"<div class='alert alert-warning'><h4>Declaration and Consent<\/h4><p>Please read the following declaration carefully before proceeding with your registration.<\/p><\/div>"}},{"className":"org.joget.apps.form.lib.CustomHTML","properties":{"id":"declarationText","label":"","value":"<div style='background-color: #f8f9fa; padding: 20px; border: 1px solid #dee2e6; border-radius: 5px; margin-bottom: 20px;'><h5>Declaration:<\/h5><p>I hereby declare that:<\/p><ol><li>All information provided in this registration form is true, accurate, and complete to the best of my knowledge.<\/li><li>I am a resident of Lesotho and engaged in agricultural activities.<\/li><li>I understand that providing false information may result in disqualification from agricultural subsidy programs.<\/li><li>I authorize the Ministry of Agriculture and Food Security to verify the information provided.<\/li><li>I understand that my information will be used for agricultural subsidy management and related government programs.<\/li><li>I agree to update my information whenever there are significant changes to my farming activities or personal circumstances.<\/li><\/ol><h5>Data Protection and Privacy:<\/h5><p>Your personal information will be:<\/p><ul><li>Protected in accordance with Lesotho's data protection laws<\/li><li>Used only for agricultural subsidy management and related government services<\/li><li>Shared only with authorized government agencies and partners<\/li><li>Kept confidential and secure<\/li><\/ul><\/div>"}},{"className":"org.joget.apps.form.lib.CheckBox","properties":{"fullWidth":"","controlField":"","readonly":"","optionsBinder":{"className":"","properties":{}},"options":[{"label":"I have read and understood the declaration above","value":"agree_declaration","grouping":""},{"label":"I agree to the terms and conditions of the agricultural subsidy programs","value":"agree_terms","grouping":""},{"label":"I consent to the verification of my information","value":"consent_verification","grouping":""},{"label":"I consent to the use of my data for agricultural program management","value":"consent_data_use","grouping":""}],"validator":{"className":"org.joget.apps.form.lib.DefaultValidator","properties":{"type":"","message":"You must agree to all terms to proceed with registration","mandatory":"true"}},"workflowVariable":"","label":"","id":"declarationConsent","value":"","readonlyLabel":""}}],"className":"org.joget.apps.form.model.Column","properties":{"width":"100%"}}],"className":"org.joget.apps.form.model.Section","properties":{"label":"Declaration","id":"declarationSection"}},{"elements":[{"elements":[{"className":"org.joget.apps.form.lib.TextField","properties":{"requiredSanitize":"","maxlength":"100","validator":{"className":"org.joget.apps.form.lib.DefaultValidator","properties":{"type":"","message":"Please enter your full name","mandatory":"true"}},"label":"Full Name (as per National ID)","encryption":"","readonly":"","size":"","workflowVariable":"","style":"","id":"declarationFullName","placeholder":"Enter your full name","value":"","readonlyLabel":"","storeNumeric":""}},{"className":"org.joget.apps.form.lib.DatePicker","properties":{"yearRange":"c-10:c+10","dataFormat":"yyyy-MM-dd","startDateFieldId":"","validator":{"className":"org.joget.apps.form.lib.DefaultValidator","properties":{"type":"","message":"","mandatory":"true"}},"format":"","label":"Date Picker","datePickerType":"","currentDateAs":"",