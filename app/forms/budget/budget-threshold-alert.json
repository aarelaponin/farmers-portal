{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "budget_threshold_alert",
    "name": "04.06 - Budget Threshold Alert",
    "tableName": "budget_threshold_alert",
    "description": "Alert log written by BudgetThresholdMonitor. One row per (envelope, severity-escalation). Severity: WATCH (≥80%), OVER (≥100%), AUTO_FREEZE (≥110% — also flips envelope status to frozen). Operators acknowledge by saving with acknowledged_at + acknowledged_by populated.",
    "loadBinder":  { "className": "org.joget.apps.form.lib.WorkflowFormBinder", "properties": {} },
    "storeBinder": { "className": "org.joget.apps.form.lib.WorkflowFormBinder", "properties": {} },
    "permission":  { "className": "", "properties": {} },
    "noPermissionMessage": "",
    "postProcessor": { "className": "", "properties": {} },
    "postProcessorRunOn": "create"
  },
  "elements": [
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": { "id": "secMain", "label": "Alert" },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "100%" },
          "elements": [
            { "className": "org.joget.apps.form.lib.TextField", "properties": { "id": "envelope_code", "label": "Envelope", "readonly": "true" } },
            { "className": "org.joget.apps.form.lib.TextField", "properties": { "id": "programme",     "label": "Programme", "readonly": "true" } },
            { "className": "org.joget.apps.form.lib.TextField", "properties": { "id": "severity",      "label": "Severity",  "readonly": "true" } },
            { "className": "org.joget.apps.form.lib.TextField", "properties": { "id": "util_pct",      "label": "Utilisation %", "readonly": "true" } },
            { "className": "org.joget.apps.form.lib.TextField", "properties": { "id": "allocated",     "label": "Allocated",  "readonly": "true" } },
            { "className": "org.joget.apps.form.lib.TextField", "properties": { "id": "used",          "label": "Used",       "readonly": "true" } },
            { "className": "org.joget.apps.form.lib.TextField", "properties": { "id": "alerted_at",    "label": "Alerted at", "readonly": "true" } }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": { "id": "secAck", "label": "Acknowledgement" },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "100%" },
          "elements": [
            { "className": "org.joget.apps.form.lib.TextField", "properties": { "id": "acknowledged_at", "label": "Acknowledged at" } },
            { "className": "org.joget.apps.form.lib.TextField", "properties": { "id": "acknowledged_by", "label": "Acknowledged by" } },
            { "className": "org.joget.apps.form.lib.TextArea",  "properties": { "id": "ack_note",        "label": "Note", "rows": "3", "cols": "80" } }
          ]
        }
      ]
    }
  ]
}
