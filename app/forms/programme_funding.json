{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "programme_funding",
    "name": "Programme Funding (donor share)",
    "tableName": "programme_funding",
    "description": "Links a programme (mm_registration) to one or more donors with a percentage share. Drives donor-grade financial reporting: each donor's allocated/committed/expensed = projection × their share. Analyst-authored.",
    "loadBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "storeBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    }
  },
  "elements": [
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": { "id": "section1", "label": "Funding Linkage" },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.IdGeneratorField",
              "properties": {
                "id": "code",
                "label": "Funding-link code (auto-generated)",
                "format": "FUND-??????",
                "envVariable": "counter",
                "isDistributedGeneration": "",
                "hidden": ""
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "programme_code",
                "label": "Programme",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "mm_registration",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "addEmptyOption": "true",
                    "emptyLabel": "(select programme)"
                  }
                },
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "donor_code",
                "label": "Donor",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "md_donor",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "addEmptyOption": "true",
                    "emptyLabel": "(select donor)"
                  }
                },
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "share_percent",
                "label": "Share % (0–100)",
                "size": "8",
                "placeholder": "e.g. 60",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "type": "numeric",
                    "message": "Share must be a number between 0 and 100"
                  }
                }
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "grant_reference",
                "label": "Grant reference (donor's internal ID)",
                "size": "60",
                "placeholder": "e.g. WFP-LSO-2026-001"
              }
            },
            {
              "className": "org.joget.apps.form.lib.DatePicker",
              "properties": {
                "id": "effective_from",
                "label": "Effective from",
                "format": "yy-mm-dd"
              }
            },
            {
              "className": "org.joget.apps.form.lib.DatePicker",
              "properties": {
                "id": "effective_to",
                "label": "Effective to",
                "format": "yy-mm-dd"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "notes",
                "label": "Notes",
                "rows": "3",
                "cols": "60"
              }
            }
          ]
        }
      ]
    }
  ]
}
