{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "im_stock_transaction",
    "name": "IM - Stock Transaction",
    "tableName": "im_stock_txn",
    "description": "Inputs Management — append-only header for stock movements (receipts, issues, adjustments, transfers). Each line row in the Items grid produces an inventory delta on the matching im_inventory row, applied by StockTransactionPostProcessor after save. Phase 3 IM Slice 6d. Per im-module SAD §5.1.",
    "loadBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "storeBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "postProcessor": {
      "className": "global.govstack.regbb.engine.processing.StockTransactionPostProcessor",
      "properties": {}
    },
    "postProcessorRunOn": "create"
  },
  "elements": [
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "headerSection",
        "label": "Transaction"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.IdGeneratorField",
              "properties": {
                "id": "code",
                "label": "Transaction code (auto-generated)",
                "format": "TXN-??????",
                "envVariable": "counter",
                "isDistributedGeneration": "",
                "hidden": ""
              }
            },
            {
              "className": "org.joget.apps.form.lib.DatePicker",
              "properties": {
                "id": "txn_date",
                "label": "Transaction date",
                "format": "yy-mm-dd",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "txn_type",
                "label": "Transaction type",
                "options": [
                  { "value": "RECEIPT",      "label": "Receipt (stock arrived from supplier)" },
                  { "value": "ISSUE",        "label": "Issue (handed over to farmer via voucher)" },
                  { "value": "ADJUSTMENT",   "label": "Adjustment (stock-count correction, damage, loss)" },
                  { "value": "TRANSFER_OUT", "label": "Transfer out (sent to another point)" },
                  { "value": "TRANSFER_IN",  "label": "Transfer in (received from another point)" }
                ],
                "addEmptyOption": "true",
                "emptyLabel": "(select)",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "district_code",
                "label": "District",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "md03district",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "addEmptyOption": "true",
                    "emptyLabel": "(select)"
                  }
                },
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "point_code",
                "label": "Resource Centre",
                "controlField": "district_code",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "md37collectionPoint",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "groupingColumn": "district_code",
                    "useAjax": "true",
                    "addEmptyOption": "true",
                    "emptyLabel": "(select district first)"
                  }
                },
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.HiddenField",
              "properties": {
                "id": "posted_at",
                "label": "Posted at (set by post-processor)"
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "itemsSection",
        "label": "Items (one row per input + quantity)"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "100%" },
          "elements": [
            {
              "className": "org.joget.plugin.enterprise.FormGrid",
              "properties": {
                "id": "items",
                "label": "",
                "formDefId": "im_stock_txn_line",
                "foreignKey": "txn_id",
                "validateAtLeastOneRow": "true",
                "options": [
                  { "value": "input_code", "label": "Input (SKU)",       "width": "40%", "formatType": "selectbox", "format": "md27input;code;name" },
                  { "value": "quantity",   "label": "Quantity",          "width": "15%" },
                  { "value": "unit_price", "label": "Unit price",        "width": "15%" },
                  { "value": "line_notes", "label": "Notes",             "width": "30%" }
                ],
                "loadBinder": {
                  "className": "org.joget.plugin.enterprise.MultirowFormBinder",
                  "properties": {
                    "formDefId": "im_stock_txn_line",
                    "foreignKey": "txn_id"
                  }
                },
                "storeBinder": {
                  "className": "org.joget.plugin.enterprise.MultirowFormBinder",
                  "properties": {
                    "formDefId": "im_stock_txn_line",
                    "foreignKey": "txn_id"
                  }
                }
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "linkageSection",
        "label": "Linkage (per type)"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "supplier_code",
                "label": "Supplier (RECEIPT only)",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "im_supplier",
                    "idColumn": "supplier_code",
                    "labelColumn": "supplier_name",
                    "addEmptyOption": "true",
                    "emptyLabel": "(n/a)"
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "supplier_invoice_no",
                "label": "Supplier invoice / GRN number (RECEIPT only)",
                "size": "64"
              }
            },
            {
              "className": "org.joget.apps.form.lib.FileUpload",
              "properties": {
                "id": "supplier_invoice_file",
                "label": "Supplier invoice / GRN scan (RECEIPT only — pdf/jpg/png)",
                "fileType": "pdf,jpg,jpeg,png",
                "maxSize": "10",
                "permissionRules": []
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "voucher_code",
                "label": "Voucher code (ISSUE only — usually populated by VoucherRedemptionTool)",
                "size": "48"
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "transfer_partner_point",
                "label": "Other point (TRANSFER_OUT / TRANSFER_IN)",
                "size": "32"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "reason_code",
                "label": "Reason code (ADJUSTMENT — damage, loss, count fix)",
                "size": "32"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "performed_by",
                "label": "Performed by (operator name)",
                "size": "100"
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "notesSection",
        "label": "Notes"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "100%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "notes",
                "label": "Notes",
                "rows": "3",
                "cols": "80"
              }
            }
          ]
        }
      ]
    }
  ]
}
