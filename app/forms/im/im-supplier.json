{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "im_supplier",
    "name": "IM - Supplier",
    "tableName": "im_supplier",
    "description": "Inputs Management — supplier registry. Companies / cooperatives / agencies that deliver inputs to MAFSN distribution points. Phase 3 IM Slice 1. Per im-module SAD §5.1.",
    "loadBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "storeBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    }
  },
  "elements": [
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "identitySection",
        "label": "Identity"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "supplier_code",
                "label": "Supplier code (immutable)",
                "size": "32",
                "maxlength": "32",
                "placeholder": "UPPER_SNAKE_CASE, e.g. SUP_LESOTHO_SEED",
                "validator": {
                  "className": "org.joget.apps.form.lib.DuplicateValueValidator",
                  "properties": {
                    "formDefId": "im_supplier",
                    "fieldId": "supplier_code",
                    "errorDuplicateMsg": "This supplier code already exists",
                    "mandatory": "true"
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "supplier_name",
                "label": "Legal / trading name",
                "size": "200",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "supplier_type",
                "label": "Supplier type",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "md_supplier_type",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "addEmptyOption": "true",
                    "emptyLabel": "(select)"
                  }
                },
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "trading_license_no",
                "label": "Trading license number",
                "size": "64"
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "contactSection",
        "label": "Contact"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "contact_phone",
                "label": "Primary phone",
                "size": "32",
                "placeholder": "+266 5xxx xxxx"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "contact_email",
                "label": "Primary email",
                "size": "100",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "type": "email",
                    "message": "Must be a valid email"
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "contact_person",
                "label": "Primary contact (person)",
                "size": "100"
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "district",
                "label": "Headquarters district",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "md03district",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "addEmptyOption": "true",
                    "emptyLabel": "(select)"
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "physical_address",
                "label": "Physical address",
                "rows": "3",
                "cols": "60"
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "certificationSection",
        "label": "Certification"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "certification_number",
                "label": "Certification number",
                "size": "64",
                "placeholder": "Free-text — agency/regulator certificate ref"
              }
            },
            {
              "className": "org.joget.apps.form.lib.DatePicker",
              "properties": {
                "id": "certification_expiry",
                "label": "Certification expiry",
                "format": "yy-mm-dd"
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "is_active",
                "label": "Active in current cycle?",
                "options": [
                  { "value": "Y", "label": "Yes" },
                  { "value": "N", "label": "No" }
                ],
                "value": "Y"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "notes",
                "label": "Notes",
                "rows": "3",
                "cols": "60"
              }
            }
          ]
        }
      ]
    }
  ]
}
