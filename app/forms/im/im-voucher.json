{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "im_voucher",
    "name": "IM - Voucher",
    "tableName": "im_voucher",
    "description": "Inputs Management — voucher record. One row per (approved application × allocation line). Issued by VoucherIssuanceTool when an application transitions to approved; redeemed at the Resource Centre by a Distribution Agent (Slice 5+). Phase 3 IM Slice 4. Per im-module SAD §5.1 + Phase E of the lifecycle.",
    "loadBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "storeBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    }
  },
  "elements": [
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "voucherSection",
        "label": "Voucher Identity"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "code",
                "label": "Voucher code",
                "size": "32",
                "maxlength": "32",
                "placeholder": "VCH-YYYYMMDD-NNNN",
                "validator": {
                  "className": "org.joget.apps.form.lib.DuplicateValueValidator",
                  "properties": {
                    "formDefId": "im_voucher",
                    "fieldId": "code",
                    "errorDuplicateMsg": "This voucher code already exists",
                    "mandatory": "true"
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.HiddenField",
              "properties": {
                "id": "application_id",
                "label": "Subsidy application UUID (FormGrid-managed FK)"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "farmer_nid",
                "label": "Farmer national ID",
                "size": "20",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "farmer_name",
                "label": "Farmer name (denormalised for the redemption screen)",
                "size": "100"
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "programme_code",
                "label": "Subsidy programme",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "mm_registration",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "addEmptyOption": "true",
                    "emptyLabel": "(select)"
                  }
                },
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.HiddenField",
              "properties": {
                "id": "allocation_line_id",
                "label": "Allocation line UUID (the rule that created this voucher)"
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "input_code",
                "label": "Input (entitlement)",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "md27input",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "addEmptyOption": "true",
                    "emptyLabel": "(select)"
                  }
                },
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "point_code",
                "label": "Allocated Resource Centre (where to redeem)",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "md37collectionPoint",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "addEmptyOption": "true",
                    "emptyLabel": "(select)"
                  }
                },
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "quantity",
                "label": "Quantity entitled",
                "size": "16",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "type": "numeric",
                    "message": "Numeric quantity required"
                  }
                }
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "lifecycleSection",
        "label": "Lifecycle"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "status",
                "label": "Status",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "md_voucher_status",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "addEmptyOption": "true",
                    "emptyLabel": "(select)"
                  }
                },
                "value": "issued",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.DatePicker",
              "properties": {
                "id": "issued_date",
                "label": "Issued on",
                "format": "yy-mm-dd",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.DatePicker",
              "properties": {
                "id": "expiry_date",
                "label": "Expiry date",
                "format": "yy-mm-dd",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.DatePicker",
              "properties": {
                "id": "redeemed_at",
                "label": "Redeemed on (filled at redemption time)",
                "format": "yy-mm-dd"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "redeemed_by",
                "label": "Redeemed by (Distribution Agent name)",
                "size": "100"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "notes",
                "label": "Notes",
                "rows": "3",
                "cols": "60"
              }
            }
          ]
        }
      ]
    }
  ]
}
