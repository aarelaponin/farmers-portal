{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "im_voucher_redemption",
    "name": "IM - Voucher Redemption",
    "tableName": "im_voucher_redemption",
    "description": "Inputs Management — one row per voucher redemption event at a Resource Centre. Written atomically when a Distribution Agent confirms redemption: voucher.status flips to 'redeemed', im_inventory is decremented, this row records the audit trail. Phase 3 IM Slice 5. Per im-module SAD §6.3 + Phase G of the lifecycle.",
    "loadBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "storeBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    }
  },
  "elements": [
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "redemptionSection",
        "label": "Redemption Event"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.IdGeneratorField",
              "properties": {
                "id": "code",
                "label": "Redemption code (auto-generated)",
                "format": "RDM-??????",
                "envVariable": "counter",
                "isDistributedGeneration": "",
                "hidden": ""
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "voucher_code",
                "label": "Voucher code",
                "size": "32",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.HiddenField",
              "properties": {
                "id": "voucher_id",
                "label": "Voucher UUID (for joins)"
              }
            },
            {
              "className": "org.joget.apps.form.lib.DatePicker",
              "properties": {
                "id": "redemption_date",
                "label": "Redemption date",
                "format": "yy-mm-dd",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "redemption_point",
                "label": "Resource Centre (where redeemed)",
                "options": [],
                "optionsBinder": {
                  "className": "org.joget.apps.form.lib.FormOptionsBinder",
                  "properties": {
                    "formDefId": "md37collectionPoint",
                    "idColumn": "code",
                    "labelColumn": "name",
                    "addEmptyOption": "true",
                    "emptyLabel": "(select)"
                  }
                },
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "redeemed_by",
                "label": "Distribution Agent (who handled redemption)",
                "size": "100",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": { "mandatory": "true" }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "quantity_redeemed",
                "label": "Quantity actually handed over",
                "size": "16",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "type": "numeric",
                    "message": "Numeric quantity required"
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.SelectBox",
              "properties": {
                "id": "status",
                "label": "Redemption status",
                "options": [
                  { "value": "completed", "label": "Completed (farmer received the input)" },
                  { "value": "reverted",  "label": "Reverted (voided after the fact)" }
                ],
                "value": "completed"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "signature_or_thumbprint",
                "label": "Signature / thumbprint reference",
                "size": "120",
                "placeholder": "Free text — file path or capture reference"
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "notesSection",
        "label": "Notes"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "100%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "notes",
                "label": "Notes",
                "rows": "3",
                "cols": "80"
              }
            }
          ]
        }
      ]
    }
  ]
}
