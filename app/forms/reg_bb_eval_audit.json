{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "reg_bb_eval_audit",
    "name": "RegBB Eval Audit",
    "tableName": "reg_bb_eval_audit",
    "description": "Per ADR-007 / spec §7.4: one row per evaluator.evaluate() call. Captures inputs/outputs/timing/evaluator route/rule snapshot so operators can trace why a determinant fired any given way for any applicant, months later. Write-only from the engine via FormDataDao.saveOrUpdate (CLAUDE.md hard rule honoured). Read-only for operators via list_reg_bb_eval_audit.",
    "loadBinder":  { "className": "org.joget.apps.form.lib.WorkflowFormBinder", "properties": {} },
    "storeBinder": { "className": "org.joget.apps.form.lib.WorkflowFormBinder", "properties": {} },
    "permission":  { "className": "", "properties": {} },
    "noPermissionMessage": "",
    "postProcessor": { "className": "", "properties": {} },
    "postProcessorRunOn": "create"
  },
  "elements": [
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": { "id": "identitySection", "label": "Identity" },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "application_id",
                "label": "Application ID",
                "size": "64",
                "maxlength": "64",
                "readonly": "true"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "applicant_name",
                "label": "Applicant Name",
                "size": "64",
                "maxlength": "128",
                "readonly": "true"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "national_id",
                "label": "National ID",
                "size": "32",
                "maxlength": "32",
                "readonly": "true"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "applied_programme",
                "label": "Applied Programme",
                "size": "32",
                "maxlength": "64",
                "readonly": "true"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "determinant_code",
                "label": "Determinant Code",
                "size": "64",
                "maxlength": "64",
                "readonly": "true"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "evaluator",
                "label": "Evaluator",
                "size": "16",
                "maxlength": "16",
                "readonly": "true"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "outcome",
                "label": "Outcome",
                "size": "16",
                "maxlength": "16",
                "readonly": "true"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "correlation_id",
                "label": "Correlation ID",
                "size": "64",
                "maxlength": "64",
                "readonly": "true"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "current_username",
                "label": "Operator (Joget user)",
                "size": "64",
                "maxlength": "64",
                "readonly": "true"
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "50%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "eval_started_at",
