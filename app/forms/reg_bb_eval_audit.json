              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "rule_version",
                "label": "Rule source (verbatim ruleJson at evaluation time)",
                "rows": "3",
                "cols": "80",
                "readonly": "true"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "error_cause",
                "label": "Error Cause (set when outcome=ERROR)",
                "rows": "2",
                "cols": "80",
                "readonly": "true"
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": { "id": "snapshotsSection", "label": "Inputs / Outputs" },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": { "width": "100%" },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "inputs_json",
                "label": "Applicant inputs (JSON snapshot of fields the rule read)",
                "rows": "5",
                "cols": "80",
                "readonly": "true"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextArea",
              "properties": {
                "id": "outputs_json",
                "label": "Outputs (full EvalResult as JSON)",
                "rows": "5",
                "cols": "80",
                "readonly": "true"
              }
            }
          ]
        }
      ]
    }
  ]
}
