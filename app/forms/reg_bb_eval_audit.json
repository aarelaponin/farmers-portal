                "size": "32",
                "maxlength": "32",
                "readonly": "true"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "eval_duration_ms",
                "label": "Duration (ms)",
                "size": "16",
                "maxlength": "16",
                "readonly": "true"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "service_id",
                "label": "Service",
                "size": "64",
                "maxlength": "64",
                "readonly": "true"
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "service_version",
                "label": "Service Version",
                "size": "32",
                "maxlength": "32",
                "readonly": "true"
              }
            }
          ]
        }
      ]
    },
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": { "id": "ruleSection", "label": "Rule snapshot" },
