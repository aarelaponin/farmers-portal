{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "spApplicationDocumentsTab",
    "name": "Application Tab \u2014 Documents",
    "description": "Application wizard documents tab. FormGrid over spApplicationDocV2. Rows seeded by application-engine SeedingTabLoadBinder + ApplicationSeedingTool from the chosen programme's document requirement spec on first visit / first save.",
    "tableName": "sp_application_doc_tab",
    "loadBinder": {
      "className": "global.govstack.application.binder.SeedingTabLoadBinder",
      "properties": {}
    },
    "storeBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "postProcessor": {
      "className": "global.govstack.application.hook.ApplicationSeedingTool",
      "properties": {}
    },
    "postProcessorRunOn": "both",
    "permission": {
      "className": "",
      "properties": {}
    },
    "noPermissionMessage": ""
  },
  "elements": [
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {"id": "main", "label": "Required documents"},
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": {"width": "100%"},
          "elements": [
            {"className": "org.joget.apps.form.lib.HiddenField",
             "properties": {"id": "parent_id", "useDefaultWhenEmpty": "", "value": "",
                            "validator": {"className": "", "properties": {}}}},
            {"className": "org.joget.apps.form.lib.CustomHTML",
             "properties": {"id": "intro", "label": "", "customParameterName": "",
                            "value": "<p style='color:#445566;font-size:13px;margin:0 0 10px 0;'>Upload the documents the programme requires. Open each row to attach a file. Status is set automatically when a file is uploaded; the case worker will VERIFY or REJECT each row during review.</p>"}},
            {"className": "org.joget.plugin.enterprise.FormGrid",
             "properties": {
               "id": "documentRequests",
               "label": "Documents",
               "formDefId": "spApplicationDocV2",
               "loadBinder": {
                 "className": "org.joget.plugin.enterprise.MultirowFormBinder",
                 "properties": {"formDefId": "spApplicationDocV2", "foreignKey": "parent_id"}
               },
               "storeBinder": {
                 "className": "org.joget.plugin.enterprise.MultirowFormBinder",
                 "properties": {"formDefId": "spApplicationDocV2", "foreignKey": "parent_id"}
               },
               "options": [
                 {"label": "Document",     "value": "doc_label",         "format": "", "width": "260", "formatType": "text"},
                 {"label": "Mandatory",    "value": "doc_mandatory",     "format": "", "width": "90",  "formatType": "text"},
                 {"label": "Accepted",     "value": "accepted_formats",  "format": "", "width": "130", "formatType": "text"},
                 {"label": "Status",       "value": "status",            "format": "", "width": "110", "formatType": "text"},
                 {"label": "Reject reason","value": "rejection_reason",  "format": "", "width": "150", "formatType": "text"}
               ],
               "showRowNumber": "true",
               "pageSize": "30"
             }}
          ]
        }
      ]
    }
  ]
}
