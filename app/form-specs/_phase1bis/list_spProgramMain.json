{
  "id": "list_spProgramMain",
  "name": "List - 03 - Support Program",
  "description": "Subsidy programmes overview with key fields surfaced via JDBC JOIN across all 8 tabs. Replaces the audit-fields-only legacy list.",
  "binder": {
    "className": "org.joget.plugin.enterprise.JdbcDataListBinder",
    "properties": {
      "jdbcDatasource": "default",
      "sql": "SELECT\n    p.id,\n    p.c_programcode AS program_code,\n    p.c_status AS status,\n    pi.c_programname AS program_name,\n    pi.c_programtype AS program_type_code,\n    md21.c_name AS program_type_label,\n    pi.c_seasoncode AS season_code,\n    md48.c_name AS season_label,\n    pg.c_geographicscope AS geographic_scope,\n    md55.c_name AS geographic_scope_label,\n    pi.c_fundingsource AS funding_source,\n    pt.c_totalbudget AS total_budget_lsl,\n    pt.c_estimatedbeneficiaries AS estimated_beneficiaries,\n    pt.c_programstartdate AS start_date,\n    pt.c_programenddate AS end_date,\n    (SELECT COUNT(*) FROM app_fd_sp_district_alloc da WHERE da.c_program_id = p.id) AS district_count,\n    p.datecreated AS created_date,\n    p.datemodified AS modified_date\nFROM app_fd_sp_program p\nLEFT JOIN app_fd_sp_program_identity pi ON pi.id = p.c_tab_identity\nLEFT JOIN app_fd_sp_program_timeline pt ON pt.id = p.c_tab_timeline\nLEFT JOIN app_fd_sp_program_geography pg ON pg.id = p.c_tab_geography\nLEFT JOIN app_fd_md21programtype md21 ON md21.c_code = pi.c_programtype\nLEFT JOIN app_fd_md48season md48 ON md48.c_code = pi.c_seasoncode\nLEFT JOIN app_fd_md55geographicscope md55 ON md55.c_code = pg.c_geographicscope\nWHERE 1=1\n  AND ('#requestParam.flt_status#' = '' OR p.c_status = '#requestParam.flt_status#')\n  AND ('#requestParam.flt_type#' = '' OR pi.c_programtype = '#requestParam.flt_type#')\n  AND ('#requestParam.flt_season#' = '' OR pi.c_seasoncode = '#requestParam.flt_season#')",
      "primaryKey": "id",
      "optimisePaging": "",
      "cacheRowCount": ""
    }
  },
