{
  "id": "list_case_notes_for_app",
  "name": "Case notes for an application",
  "description": "Append-only thread of operator notes for one application. Embedded on the operator review form via filterParams.application_id=#recordId#. Sorted newest first.",
  "useSession": "false",
  "showPageSizeSelector": "false",
  "pageSize": "20",
  "order": "desc",
  "orderBy": "created_at",
  "binder": {
    "className": "org.joget.plugin.enterprise.AdvancedFormRowDataListBinder",
    "properties": {
      "formDefId": "case_note"
    }
  },
  "columns": [
    {
      "name": "created_at",
      "id": "col_when",
      "label": "When",
      "sortable": "true",
      "formats": [
        { "className": "org.joget.plugin.enterprise.DateFormatter",
          "properties": { "format": "dd MMM yyyy HH:mm", "rawFormat": "yyyy-MM-dd HH:mm:ss" } }
      ]
    },
    {
      "name": "author",
      "id": "col_author",
      "label": "Operator"
    },
    {
      "name": "note_kind",
      "id": "col_kind",
      "label": "Kind",
      "formats": [
        {
          "className": "org.joget.plugin.enterprise.OptionsValueFormatter",
          "properties": {
            "formDefId": "md_case_note_kind",
            "idColumn": "code",
            "labelColumn": "name"
          }
        }
      ]
    },
    {
      "name": "note_text",
      "id": "col_text",
      "label": "Note"
    }
  ],
  "filters": [
    {
      "name": "application_id",
      "id": "filter_app",
      "label": "Application",
      "hidden": "true",
      "type": {
        "className": "org.joget.apps.datalist.lib.TextFieldDataListFilterType",
        "properties": { "defaultValue": "" }
      }
    }
  ],
  "actions": [],
  "rowActions": []
}
