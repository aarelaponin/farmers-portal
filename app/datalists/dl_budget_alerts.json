{
  "useSession": "false",
  "showPageSizeSelector": "true",
  "rowActions": [],
  "columns": [
    { "name": "alerted_at",    "id": "column_at",     "label": "Alerted",       "width": "150px" },
    { "name": "severity_html", "id": "column_sev",    "label": "Severity",      "width": "140px", "renderHtml": "true" },
    { "name": "envelope_code", "id": "column_env",    "label": "Envelope",      "width": "200px" },
    { "name": "programme",     "id": "column_prog",   "label": "Programme",     "width": "240px" },
    { "name": "util_pct_disp", "id": "column_pct",    "label": "Util %",        "width": "90px",  "alignment": "right" },
    { "name": "allocated_disp","id": "column_alloc",  "label": "Allocated",     "width": "120px", "alignment": "right" },
    { "name": "used_disp",     "id": "column_used",   "label": "Used",          "width": "120px", "alignment": "right" },
    { "name": "ack_status",    "id": "column_ack",    "label": "Acknowledged?", "width": "130px" }
  ],
  "pageSize": 0,
  "orderBy": "",
  "filters": [],
  "pageSizeSelectorOptions": "10,20,50,100",
  "buttonPosition": "bothLeft",
  "checkboxPosition": "left",
  "name": "Budget — Alerts",
  "id": "dl_budget_alerts",
  "binder": {
    "className": "org.joget.plugin.enterprise.JdbcDataListBinder",
    "properties": {
      "datasource": "default",
      "sql": "SELECT id, c_alerted_at AS alerted_at, c_envelope_code AS envelope_code, COALESCE(c_programme, '—') AS programme, COALESCE(c_util_pct, '—') || '%' AS util_pct_disp, to_char(CAST(NULLIF(c_allocated,'') AS NUMERIC(15,2)), 'FM999,999,999.00') AS allocated_disp, to_char(CAST(NULLIF(c_used,'') AS NUMERIC(15,2)), 'FM999,999,999.00') AS used_disp, CASE WHEN c_severity = 'WATCH'        THEN '<span style=\"display:inline-flex;align-items:center;gap:6px;padding:2px 10px;border-radius:12px;background:#fff4e0;color:#7a5d00;font-size:0.82em;font-weight:600;\"><span style=\"width:8px;height:8px;border-radius:50%;background:#e6a700;\"></span>WATCH ≥80%</span>' WHEN c_severity = 'OVER'         THEN '<span style=\"display:inline-flex;align-items:center;gap:6px;padding:2px 10px;border-radius:12px;background:#fdecea;color:#9b2520;font-size:0.82em;font-weight:600;\"><span style=\"width:8px;height:8px;border-radius:50%;background:#9b2520;\"></span>OVER ≥100%</span>' WHEN c_severity = 'AUTO_FREEZE'  THEN '<span style=\"display:inline-flex;align-items:center;gap:6px;padding:2px 10px;border-radius:12px;background:#fce7e7;color:#7b1818;font-size:0.82em;font-weight:600;\"><span style=\"width:8px;height:8px;border-radius:50%;background:#7b1818;\"></span>AUTO-FROZEN ≥110%</span>' ELSE c_severity END AS severity_html, CASE WHEN COALESCE(c_acknowledged_at,'') = '' THEN 'pending' ELSE 'ack by ' || COALESCE(c_acknowledged_by, '?') END AS ack_status FROM app_fd_budget_threshold_alert ORDER BY CASE WHEN COALESCE(c_acknowledged_at,'') = '' THEN 0 ELSE 1 END, datecreated DESC",
      "countSql": "SELECT count(*) FROM app_fd_budget_threshold_alert",
      "primaryKey": "id"
    }
  },
  "actions": [],
  "order": ""
}
