    { "name": "programme_code",   "id": "column_prog",  "label": "Programme",    "width": "150px" },
    { "name": "stage_at_failure", "id": "column_stg",   "label": "Failed at stage","width": "150px" },
    { "name": "attempts_used",    "id": "column_att",   "label": "Attempts",     "width": "80px",  "alignment": "right" },
    { "name": "last_error",       "id": "column_err",   "label": "Last error" },
    { "name": "resolved_by",      "id": "column_resby", "label": "Resolved by",  "width": "120px" },
    { "name": "resolved_at",      "id": "column_resat", "label": "Resolved",     "width": "150px" }
  ],
  "pageSize": 0,
  "orderBy": "",
  "filters": [],
  "pageSizeSelectorOptions": "10,20,50,100",
  "buttonPosition": "bothLeft",
  "checkboxPosition": "left",
  "name": "Processing — dead-letter",
  "id": "dl_processing_dead_letter",
  "binder": {
    "className": "org.joget.plugin.enterprise.JdbcDataListBinder",
    "properties": {
      "datasource": "default",
      "sql": "SELECT id, c_dead_lettered_at AS dead_lettered_at, COALESCE(c_applicant_nid, '—') AS applicant_nid, COALESCE(c_programme_code, '—') AS programme_code, COALESCE(c_stage_at_failure, '—') AS stage_at_failure, COALESCE(c_attempts_used, '—') AS attempts_used, COALESCE(LEFT(c_last_error, 160), '') AS last_error, COALESCE(c_resolved_by, '—') AS resolved_by, COALESCE(c_resolved_at, '') AS resolved_at, CASE WHEN c_resolution = 'open' OR c_resolution IS NULL THEN '<span style=\"display:inline-flex;align-items:center;gap:6px;padding:2px 10px;border-radius:12px;background:#fdecea;color:#9b2520;font-size:0.82em;font-weight:600;\"><span style=\"width:8px;height:8px;border-radius:50%;background:#9b2520;\"></span>open</span>' WHEN c_resolution = 're_enqueued' THEN '<span style=\"display:inline-flex;align-items:center;gap:6px;padding:2px 10px;border-radius:12px;background:#dbeafe;color:#1e40af;font-size:0.82em;\"><span style=\"width:8px;height:8px;border-radius:50%;background:#3b82f6;\"></span>re-enqueued</span>' WHEN c_resolution = 'manually_failed' THEN '<span style=\"display:inline-flex;align-items:center;gap:6px;padding:2px 10px;border-radius:12px;background:#fef3c7;color:#92400e;font-size:0.82em;\"><span style=\"width:8px;height:8px;border-radius:50%;background:#f59e0b;\"></span>manual fail</span>' WHEN c_resolution = 'unrecoverable' THEN '<span style=\"display:inline-flex;align-items:center;gap:6px;padding:2px 10px;border-radius:12px;background:#eceff1;color:#546e7a;font-size:0.82em;\"><span style=\"width:8px;height:8px;border-radius:50%;background:#90a4ae;\"></span>unrecoverable</span>' ELSE c_resolution END AS resolution_html FROM app_fd_processing_dead_letter ORDER BY CASE WHEN c_resolution = 'open' OR c_resolution IS NULL THEN 0 ELSE 1 END, c_dead_lettered_at DESC NULLS LAST",
      "countSql": "SELECT count(*) FROM app_fd_processing_dead_letter",
      "primaryKey": "id"
    }
  },
  "actions": [],
  "order": ""
}
