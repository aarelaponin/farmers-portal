{"useSession":"false","showPageSizeSelector":"true","rowActions":[],"columns":[{"name":"code","id":"column_code","label":"Code"},{"name":"status_html","id":"column_status","label":"Status","renderHtml":"true"},{"name":"adjustment_type","id":"column_type","label":"Type"},{"name":"from_envelope_code","id":"column_from","label":"From"},{"name":"to_envelope_code","id":"column_to","label":"To"},{"name":"amount_disp","id":"column_amt","label":"Amount","alignment":"right"},{"name":"requested_by","id":"column_reqby","label":"Requested by"},{"name":"requested_at","id":"column_reqat","label":"Requested"},{"name":"approved_by","id":"column_appby","label":"Approved by"},{"name":"approved_at","id":"column_appat","label":"Approved"}],"pageSize":0,"orderBy":"","filters":[],"pageSizeSelectorOptions":"10,20,50,100","buttonPosition":"bothLeft","checkboxPosition":"left","name":"Budget \u2014 Manual adjustments","id":"dl_budget_adjustments","binder":{"className":"org.joget.plugin.enterprise.JdbcDataListBinder","properties":{"datasource":"default","sql":"SELECT id, c_code AS code, c_adjustment_type AS adjustment_type, COALESCE(c_from_envelope_code, '\u2014') AS from_envelope_code, COALESCE(c_to_envelope_code, '\u2014') AS to_envelope_code, to_char(CAST(NULLIF(c_amount,'') AS NUMERIC(15,2)), 'FM999,999,999.00') AS amount_disp, COALESCE(c_requested_by, '\u2014') AS requested_by, c_requested_at AS requested_at, COALESCE(c_approved_by, '\u2014') AS approved_by, c_approved_at AS approved_at, CASE WHEN c_status = 'requested' THEN '<span style=\"display:inline-flex;align-items:center;gap:6px;padding:2px 10px;border-radius:12px;background:#fff4e0;color:#7a5d00;font-size:0.82em;font-weight:600;\"><span style=\"width:8px;height:8px;border-radius:50%;background:#e6a700;\"></span>requested</span>' WHEN c_status = 'approved' THEN '<span style=\"display:inline-flex;align-items:center;gap:6px;padding:2px 10px;border-radius:12px;background:#e6f4ea;color:#1e6b34;font-size:0.82em;font-weight:600;\"><span style=\"width:8px;height:8px;border-radius:50%;background:#2e7d32;\"></span>approved</span>' WHEN c_status = 'rejected' THEN '<span style=\"display:inline-flex;align-items:center;gap:6px;padding:2px 10px;border-radius:12px;background:#fdecea;color:#9b2520;font-size:0.82em;font-weight:600;\"><span style=\"width:8px;height:8px;border-radius:50%;background:#9b2520;\"></span>rejected</span>' ELSE c_status END AS status_html FROM app_fd_budget_adjustment ORDER BY CASE WHEN c_status = 'requested' THEN 0 ELSE 1 END, datecreated DESC","countSql":"SELECT count(*) FROM app_fd_budget_adjustment","primaryKey":"id"}},"actions":[],"order":""}