{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "spApplicationDecision",
    "name": "Application Tab 5 — Decision (operator)",
    "description": "Tab 5 of the application wizard. Operator-facing review and decision: APPROVE / REJECT / REQUEST_INFO. Wired to the decision-engine post-processor.",
    "tableName": "sp_application_decision",
    "loadBinder": {"className": "org.joget.apps.form.lib.WorkflowFormBinder", "properties": {}},
    "storeBinder": {"className": "global.govstack.decision.binder.DecisionStoreBinder", "properties": {}},
    "permission": {"className": "", "properties": {}}
  },
  "elements": [
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {"id": "main", "label": "Operator decision"},
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": {"width": "100%"},
          "elements": [
            {"className": "org.joget.apps.form.lib.HiddenField",
             "properties": {"id": "parent_id", "label": "Parent (application id)"}},
            {"className": "org.joget.apps.form.lib.CustomHTML",
             "properties": {
               "id": "intro",
               "label": "",
               "value": "<p style='color:#445566;font-size:13px;margin:0 0 14px 0;'>Review the eligibility responses and benefit requests on the previous tabs. Choose a decision; on Save the application status updates, an audit row is written, and on <b>Approve</b> an entitlement record is issued automatically.</p>"}},
            {"className": "org.joget.apps.form.lib.SelectBox",
             "properties": {
               "id": "decision",
               "label": "Decision *",
               "options": [
                 {"value": "",             "label": "— select a decision —"},
                 {"value": "APPROVE",      "label": "Approve — issue entitlement"},
                 {"value": "REJECT",       "label": "Reject — close application"},
                 {"value": "REQUEST_INFO", "label": "Request more information"}
               ],
               "validator": {"className": "org.joget.apps.form.lib.DefaultValidator",
                             "properties": {"mandatory": "true"}}}},
            {"className": "org.joget.apps.form.lib.TextArea",
             "properties": {
               "id": "decision_reason",
               "label": "Reason / notes *",
               "rows": "4",
               "validator": {"className": "org.joget.apps.form.lib.DefaultValidator",
                             "properties": {"mandatory": "true"}}}},
            {"className": "org.joget.apps.form.lib.TextField",
             "properties": {
               "id": "decision_signoff",
               "label": "Signoff (your full name)",
               "size": "60", "maxlength": "200"}},
            {"className": "org.joget.apps.form.lib.DatePicker",
             "properties": {"id": "decision_date", "label": "Decision date"}}
          ]
        }
      ]
    }
  ]
}
