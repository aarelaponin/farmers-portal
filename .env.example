# ---------------------------------------------------------------------------
# Farmers Portal — environment template
# ---------------------------------------------------------------------------
# Copy this file to `.env`, fill in the values, and either:
#   export $(grep -v '^#' .env | xargs)         # POSIX shells
# or source it via your tool of choice (direnv, dotenv, etc.).
#
# Every variable below is required for `make fresh-install` to succeed unless
# explicitly marked OPTIONAL. See INSTALL.md for the install playbook.
# ---------------------------------------------------------------------------

# --- Joget instance ---------------------------------------------------------
# Base URL of your Joget DX 8.1 server (no trailing slash).
JOGET_BASE_URL=http://localhost:8080/jw

# Joget app id we install into. Leave as `farmersPortal` for the canonical
# install; change only if you renamed the app shell in App Composer.
JOGET_APP_ID=farmersPortal

# API Builder credentials for the form-creator-api endpoints. After uploading
# the form-creator-api plugin JAR, log into App Composer → API Builder → open
# the `formcreator` API → create an API Credential. Copy api_id (looks like
# `API-<uuid>`) and api_key (any string of your choosing — Joget hashes it).
JOGET_API_ID=API-00000000-0000-0000-0000-000000000000
JOGET_API_KEY=change-me-to-a-random-secret

# --- Postgres backing store -------------------------------------------------
# Connection used by `tooling/sync_pull.py` and the per-form data API readers.
# Joget itself connects via wflow/app_datasource — these env vars only drive
# the install scripts and the sync ritual (ADR-033).
PGHOST=localhost
PGPORT=5432
PGDATABASE=jogetdb
PGUSER=jogetadmin
PGPASSWORD=change-me

# --- SMTP (OPTIONAL — needed only for the notifier subsystem) ---------------
# If unset, notification emails get queued but never sent. Fine for first
# install and smoke testing; required before UAT.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=youraddr@gmail.com
# SMTP_PASSWORD=app-password-16-chars
# SMTP_FROM=youraddr@gmail.com

# --- Test-mode override (OPTIONAL — single email-redirect for UAT) ----------
# JVM system properties set on the Joget Tomcat. Equivalent shell vars below
# for documentation; set them in setenv.sh or CATALINA_OPTS, not here.
# regbb.notif.testMode=true
# regbb.notif.testEmail=qa@example.org
